import torch
from torch_geometric.datasets import Planetoid
from torch_geometric.nn import GCNConv
from torch_geometric.utils import negative_sampling, train_test_split_edges

# 1. 加载数据并划分边
dataset = Planetoid(root='/tmp/Cora', name='Cora')
data = dataset[0]
data = train_test_split_edges(data)  # 自动划分训练/验证/测试边

# 2. 定义编码器
class GCNEncoder(torch.nn.Module):
    def __init__(self, in_channels, out_channels):
        super().__init__()
        self.conv1 = GCNConv(in_channels, 2 * out_channels)
        self.conv2 = GCNConv(2 * out_channels, out_channels)
    
    def forward(self, x, edge_index):
        x = self.conv1(x, edge_index).relu()
        return self.conv2(x, edge_index)

# 3. 定义解码器（点积）
def decode(z, edge_index):
    # z: 节点嵌入 (num_nodes, embedding_dim)
    # edge_index: 边索引 (2, num_edges)
    return (z[edge_index[0]] * z[edge_index[1]]).sum(dim=-1)

def decode_all(z):
    # 计算所有节点对的得分
    prob_adj = z @ z.t()
    return (prob_adj > 0).nonzero(as_tuple=False).t()

# 4. 训练
model = GCNEncoder(dataset.num_features, 64)
optimizer = torch.optim.Adam(model.parameters(), lr=0.01)

def train():
    model.train()
    optimizer.zero_grad()
    
    # 编码
    z = model(data.x, data.train_pos_edge_index)
    
    # 正样本损失
    pos_loss = -torch.log(
        torch.sigmoid(decode(z, data.train_pos_edge_index)) + 1e-15
    ).mean()
    
    # 负采样
    neg_edge_index = negative_sampling(
        edge_index=data.train_pos_edge_index,
        num_nodes=data.num_nodes,
        num_neg_samples=data.train_pos_edge_index.size(1)
    )
    
    # 负样本损失
    neg_loss = -torch.log(
        1 - torch.sigmoid(decode(z, neg_edge_index)) + 1e-15
    ).mean()
    
    loss = pos_loss + neg_loss
    loss.backward()
    optimizer.step()
    return loss.item()

@torch.no_grad()
def test():
    model.eval()
    z = model(data.x, data.train_pos_edge_index)
    
    # 计算 AUC
    from sklearn.metrics import roc_auc_score
    
    pos_pred = torch.sigmoid(decode(z, data.test_pos_edge_index))
    neg_pred = torch.sigmoid(decode(z, data.test_neg_edge_index))
    
    pred = torch.cat([pos_pred, neg_pred]).cpu()
    y = torch.cat([torch.ones(pos_pred.size(0)), torch.zeros(neg_pred.size(0))])
    
    return roc_auc_score(y, pred)

for epoch in range(1, 201):
    loss = train()
    if epoch % 20 == 0:
        auc = test()
        print(f'Epoch: {epoch:03d}, Loss: {loss:.4f}, AUC: {auc:.4f}')
