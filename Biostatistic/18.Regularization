# L1 Regularization - LASSO--------------------------------------------------------------
fit <- cv.glmnet(as.matrix(t(data)), group, alpha = 1, nfolds = 10, family = binomial(link = 'logit'), type.measure = 'auc')

coef <- coef(fit, s = fit$lambda.min)
prob <- predict(fit.lasso, newx = as.matrix(t(data)), s = "lambda.min", type = "response")
modelroc <- roc(group, unlist(prob[,1]))
modelroc

