# Elastic Net ---------------------------------------------------------------------------
alpha (0-1)
fit <- cv.glmnet(as.matrix(t(data)), group, alpha = alpha, nfolds = 10, family = binomial(link = 'logit'), type.measure = 'auc')

# Adaptive LASSO ------------------------------------------------------------------------
do not do recursive LASSO: 
data > LASSO1 > features1 > data[,features1] > LASSO2 > ...

use penalty.factor para to set weight, coef can be β from ridge or else regressions. note: make sure coef is not 0.

fit.lasso <- cv.glmnet(
  as.matrix(t(data)), 
  group, 
  alpha = 0.2, 
  nfolds = 10, 
  family = binomial(link = 'logit'), 
  type.measure = 'auc'
  penalty.factor = 1/abs(coef)))
